#!/bin/bash

# OS Project Development Helper Script

# Check if we are in the correct directory (optional safety check)
if [ ! -f "Makefile" ]; then
    echo "Error: Makefile not found. Please run this command in the project root."
    exit 1
fi

if [ "$1" == "image" ]; then
    echo ">>> [dev] 1. Restoring base image..."
    # Decompress the raw sparse image (reset disk state)
    if [ -f "100m.img.tar.gz" ]; then
        tar xzf 100m.img.tar.gz
    else
        echo "Warning: 100m.img.tar.gz not found. Using existing 100m.img if present."
    fi

    echo ">>> [dev] 2. Building project (make image)..."
    make image

    # Check if make succeeded
    if [ $? -eq 0 ]; then
        echo ">>> [dev] 3. Compressing artifact..."
        # Remove old artifact to ensure freshness
        rm -f 100m.img.tar.xz
        # Compress the modified image using xz
        tar cJf 100m.img.tar.xz 100m.img
        
        echo ">>> [dev] Build Success! Artifact ready: 100m.img.tar.xz"
    else
        echo ">>> [dev] Build Failed."
        exit 1
    fi
else
    # Pass all other arguments directly to make (e.g., 'dev clean' -> 'make clean')
    echo ">>> [dev] Executing: make $@"
    make "$@"
fi
