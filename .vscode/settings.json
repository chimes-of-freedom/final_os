{
	"editor.insertSpaces": false,
	"editor.tabSize": 8,
	"editor.detectIndentation": false,
	"editor.renderWhitespace": "all",
	"files.eol": "\n",
	"files.associations": {
		"dev": "shellscript"
	},
	"[c]": {
		"editor.tabSize": 8,
		"editor.insertSpaces": false
	},
	"[cpp]": {
		"editor.tabSize": 8,
		"editor.insertSpaces": false
	},
	"files.exclude": {
		"**/*.o": true,
		"**/*.bin": true
	}
}